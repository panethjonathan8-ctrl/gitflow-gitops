# Copy this file to secrets.hcl and fill in real values.
# secrets.hcl is gitignored — see .gitignore. Never commit the real file.
# This mirrors how terraform.tfvars.example / terraform.tfvars worked before.
#
# grafana_admin_password, github_oauth_client_secret, and
# argocd_github_oauth_client_secret are NOT here — those are synced into the
# cluster from AWS Secrets Manager by External Secrets Operator (see
# modules/eso) instead of being passed through Terraform. Set them once with:
#   aws secretsmanager put-secret-value --secret-id <project>/dev/grafana-admin-password --secret-string '<value>'
#   aws secretsmanager put-secret-value --secret-id <project>/dev/grafana-github-oauth-client-secret --secret-string '<value>'
#   aws secretsmanager put-secret-value --secret-id <project>/dev/argocd-github-oauth-client-secret --secret-string '<value>'
locals {
  github_oauth_client_id        = "changeme"
  github_oauth_allowed_user     = "changeme"
  argocd_github_oauth_client_id = "changeme"
  argocd_github_allowed_user    = "changeme"
}
